ARG REPOSITORY=docker.osdc.io
ARG BUILDER_TAG=3.1.0

# Proxy args (pass from CI via build.sh)
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG no_proxy

# -----------------------------
# Builder (amzn2023-builder + dnf): fetch mirna source + seed files
# -----------------------------
FROM ${REPOSITORY}/ncigdc/amzn2023-builder:${BUILDER_TAG} AS builder

ARG VERSION

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG no_proxy

ENV HTTP_PROXY=${HTTP_PROXY}
ENV HTTPS_PROXY=${HTTPS_PROXY}
ENV NO_PROXY=${NO_PROXY}
ENV http_proxy=${http_proxy}
ENV https_proxy=${https_proxy}
ENV no_proxy=${no_proxy}

RUN set -eux; \
  dnf -y makecache --refresh; \
  dnf -y install \
    wget \
    tar \
    gzip \
    bzip2 \
    xz \
    findutils \
    ca-certificates; \
  dnf clean all

# --- MIRNA SOURCE (NO GIT) ---
# mirna-mirror uses master
ARG MIRNA_REF=master
RUN set -eux; \
  mkdir -p /out/usr; \
  (wget -O /tmp/mirna.tar.gz "https://codeload.github.com/NCI-GDC/mirna-mirror/tar.gz/${MIRNA_REF}" \
   || wget -O /tmp/mirna.tar.gz "https://github.com/NCI-GDC/mirna-mirror/archive/refs/heads/${MIRNA_REF}.tar.gz"); \
  tar -xzf /tmp/mirna.tar.gz -C /out/usr; \
  rm -f /tmp/mirna.tar.gz; \
  srcdir="$(find /out/usr -maxdepth 1 -type d -name 'mirna-mirror-*' | head -n 1)"; \
  test -n "${srcdir}"; \
  mv "${srcdir}" /out/usr/mirna

# hg38 seed files (same set + same renames as legacy Dockerfile)
RUN set -eux; \
  mkdir -p /out/seed/hg38; \
  cd /out/seed/hg38; \
  base="http://hgdownload.cse.ucsc.edu/goldenpath/hg38/database"; \
  wget -q ${base}/chromInfo.sql; \
  wget -q ${base}/chromInfo.txt.gz; \
  wget -q ${base}/gap.sql; \
  wget -q ${base}/gap.txt.gz; \
  wget -q ${base}/gold.sql; \
  wget -q ${base}/gold.txt.gz; \
  wget -q ${base}/grp.sql; \
  wget -q ${base}/grp.txt.gz; \
  wget -q ${base}/hgFindSpec.sql; \
  wget -q ${base}/hgFindSpec.txt.gz; \
  wget -q ${base}/kgXref.sql; \
  wget -q ${base}/kgXref.txt.gz; \
  wget -q ${base}/knownGene.sql; \
  wget -q ${base}/knownGene.txt.gz; \
  wget -q ${base}/refGene.sql; \
  wget -q ${base}/refGene.txt.gz; \
  wget -q ${base}/rmsk.sql; \
  wget -q ${base}/rmsk.txt.gz; \
  wget -q ${base}/trackDb.sql; \
  wget -q ${base}/trackDb.txt.gz; \
  gunzip -f *.gz; \
  mv chromInfo.txt chromInfo.tsv; \
  mv gap.txt gap.tsv; \
  mv gold.txt gold.tsv; \
  mv grp.txt grp.tsv; \
  mv hgFindSpec.txt hgFindSpec.tsv; \
  mv kgXref.txt kgXref.tsv; \
  mv knownGene.txt knownGene.tsv; \
  mv refGene.txt refGene.tsv; \
  mv rmsk.txt rmsk.tsv; \
  mv trackDb.txt trackDb.tsv

# mirbase v21 seed files (same processing as legacy Dockerfile)
RUN set -eux; \
  mkdir -p /out/seed/mirbase; \
  cd /out/seed/mirbase; \
  base="ftp://mirbase.org/pub/mirbase/21"; \
  wget -q ${base}/0_THIS_IS_RELEASE_21 || true; \
  wget -q ${base}/README || true; \
  wget -q ${base}/database_files/tables.sql; \
  for f in \
    confidence_score.txt.gz \
    confidence.txt.gz \
    dead_mirna.txt.gz \
    experiment_pre_read.txt.gz \
    experiment.txt.gz \
    literature_references.txt.gz \
    mature_pre_read.txt.gz \
    mature_read_count_by_experiment.txt.gz \
    mature_read_count.txt.gz \
    mirna_2_prefam.txt.gz \
    mirna2wikipedia.txt.gz \
    mirna_chromosome_build.txt.gz \
    mirna_context.txt.gz \
    mirna_database_links.txt.gz \
    mirna_mature.txt.gz \
    mirna_prefam.txt.gz \
    mirna_pre_mature.txt.gz \
    mirna_pre_read.txt.gz \
    mirna_read_count_by_experiment.txt.gz \
    mirna_read_count.txt.gz \
    mirna_read_experiment_count.txt.gz \
    mirna_read.txt.gz \
    mirna_species.txt.gz \
    mirna_target_links.txt.gz \
    mirna_target_url.txt.gz \
    mirna.txt.gz \
    wikipedia.txt.gz \
  ; do \
    wget -q ${base}/database_files/$f; \
  done; \
  gunzip -f *.gz; \
  for f in *.txt; do mv "$f" "${f%.txt}.tsv"; done; \
  awk 'BEGIN{FS=OFS="\t"}{print $1,$2,$3,$4}' mirna_read_count.tsv > mirna_read_count.tsv.trunc; \
  mv mirna_read_count.tsv.trunc mirna_read_count.tsv


# -----------------------------
# Runtime (amzn2023 + dnf): install deps, configure users, bake DBs, shutdown
# -----------------------------
FROM ${REPOSITORY}/ncigdc/amzn2023:${BUILDER_TAG}

ARG VERSION

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG no_proxy

ENV HTTP_PROXY=${HTTP_PROXY}
ENV HTTPS_PROXY=${HTTPS_PROXY}
ENV NO_PROXY=${NO_PROXY}
ENV http_proxy=${http_proxy}
ENV https_proxy=${https_proxy}
ENV no_proxy=${no_proxy}

ENV mirna_profiler=0.2.8gdc
ENV mirna_userid=33
ENV mirna_user=ubuntu
ENV mirna_groupid=33
ENV mirna_group=ubuntu

RUN set -eux; \
  dnf repolist || true; \
  dnf -y makecache --refresh

# Core deps (closest equivalents)
RUN set -eux; \
  dnf -y install \
    wget \
    sudo \
    perl \
    perl-DBI \
    shadow-utils \
    gzip \
    tar \
    ca-certificates; \
  dnf clean all

# Optional / varying names across images
RUN set -eux; \
  (dnf -y install findutils || true); \
  (dnf -y install vim-enhanced \
    || dnf -y install vim \
    || dnf -y install vim-minimal \
    || true); \
  (dnf -y install perl-DBD-MySQL \
    || dnf -y install perl-DBD-MariaDB \
    || true); \
  (dnf -y install R \
    || dnf -y install R-core \
    || true); \
  dnf clean all || true

# DB server/client (required to mirror legacy behavior of baking DBs into image)
RUN set -eux; \
  if dnf -y install mariadb-server mariadb mariadb-client; then \
    echo "Installed mariadb-server"; \
  elif dnf -y install mariadb105-server mariadb105 mariadb105-client; then \
    echo "Installed mariadb105-server"; \
  elif dnf -y install community-mysql-server community-mysql; then \
    echo "Installed community-mysql-server"; \
  else \
    echo "ERROR: Could not install any MySQL/MariaDB server packages from enabled dnf repos." >&2; \
    exit 1; \
  fi; \
  dnf clean all

# Copy mirna + seed data from builder
COPY --from=builder /out/usr/mirna /usr/mirna
COPY --from=builder /out/seed/hg38 /opt/seed/hg38
COPY --from=builder /out/seed/mirbase /opt/seed/mirbase

# User/group setup (mirrors legacy intent)
RUN set -eux; \
  if ! getent group "${mirna_groupid}" >/dev/null; then \
    groupadd -g "${mirna_groupid}" "${mirna_group}"; \
  else \
    existing="$(getent group "${mirna_groupid}" | cut -d: -f1)"; \
    if [ "${existing}" != "${mirna_group}" ]; then groupmod -n "${mirna_group}" "${existing}"; fi; \
  fi; \
  if ! getent passwd "${mirna_userid}" >/dev/null; then \
    useradd -m -u "${mirna_userid}" -g "${mirna_groupid}" -s /bin/bash "${mirna_user}"; \
  else \
    existing="$(getent passwd "${mirna_userid}" | cut -d: -f1)"; \
    if [ "${existing}" != "${mirna_user}" ]; then usermod -l "${mirna_user}" "${existing}"; fi; \
  fi; \
  usermod -aG wheel "${mirna_user}"; \
  echo "${mirna_user} ALL=(ALL) NOPASSWD:ALL" > "/etc/sudoers.d/${mirna_user}"; \
  chmod 0440 "/etc/sudoers.d/${mirna_user}"; \
  \
  if ! getent group 1000 >/dev/null; then groupadd -g 1000 default; fi; \
  if ! getent passwd 1000 >/dev/null; then \
    useradd -m -u 1000 -g 1000 -s /bin/bash default; \
    usermod -aG wheel default; \
    usermod -aG "${mirna_group}" default; \
    echo "default ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/default; \
    chmod 0440 /etc/sudoers.d/default; \
  fi

# Legacy config lines + ownership
RUN set -eux; \
  printf "hg38\tlocalhost\troot\t\n" >> /usr/mirna/config/db_connections.cfg; \
  printf "mirbase\tlocalhost\troot\t\n" >> /usr/mirna/config/db_connections.cfg; \
  chown -R "${mirna_user}.${mirna_group}" /usr/mirna

# Bake hg38 + mirbase into /var/lib/mysql during build, then shutdown (legacy behavior)
RUN set -eux; \
  if command -v mariadbd >/dev/null 2>&1; then DB_DAEMON="mariadbd"; \
  elif command -v mysqld >/dev/null 2>&1; then DB_DAEMON="mysqld"; \
  else echo "ERROR: DB daemon not found after install" >&2; exit 1; fi; \
  \
  mkdir -p /var/run/mysqld; \
  chown -R mysql:mysql /var/run/mysqld; \
  \
  # best-effort equivalent to: echo 'secure-file-priv=""' >> mysqld cnf
  if [ -f /etc/my.cnf.d/mariadb-server.cnf ]; then \
    echo 'secure-file-priv=""' >> /etc/my.cnf.d/mariadb-server.cnf; \
  elif [ -f /etc/my.cnf.d/server.cnf ]; then \
    echo 'secure-file-priv=""' >> /etc/my.cnf.d/server.cnf; \
  else \
    echo 'secure-file-priv=""' >> /etc/my.cnf; \
  fi; \
  \
  $DB_DAEMON --user=mysql --datadir=/var/lib/mysql \
    --socket=/var/run/mysqld/mysqld.sock \
    --pid-file=/var/run/mysqld/mysqld.pid \
    --bind-address=127.0.0.1 --daemonize; \
  mysqladmin --protocol=socket --socket=/var/run/mysqld/mysqld.sock ping --silent --wait=60; \
  \
  # hg38
  mysql --protocol=socket --socket=/var/run/mysqld/mysqld.sock -e "create database hg38"; \
  cd /opt/seed/hg38; \
  cat kgXref.sql    | mysql --protocol=socket --socket=/var/run/mysqld/mysqld.sock --user=root --database=hg38; \
  cat knownGene.sql | mysql --protocol=socket --socket=/var/run/mysqld/mysqld.sock --user=root --database=hg38; \
  cat refGene.sql   | mysql --protocol=socket --socket=/var/run/mysqld/mysqld.sock --user=root --database=hg38; \
  cat rmsk.sql      | mysql --protocol=socket --socket=/var/run/mysqld/mysqld.sock --user=root --database=hg38; \
  mysqlimport --protocol=socket --socket=/var/run/mysqld/mysqld.sock --local --user root hg38 kgXref.tsv; \
  mysqlimport --protocol=socket --socket=/var/run/mysqld/mysqld.sock --local --user root hg38 knownGene.tsv; \
  mysqlimport --protocol=socket --socket=/var/run/mysqld/mysqld.sock --local --user root hg38 refGene.tsv; \
  mysqlimport --protocol=socket --socket=/var/run/mysqld/mysqld.sock --local --user root hg38 rmsk.tsv; \
  \
  # mirbase
  mysql --protocol=socket --socket=/var/run/mysqld/mysqld.sock -e "create database mirbase"; \
  cd /opt/seed/mirbase; \
  cat tables.sql | mysql --protocol=socket --socket=/var/run/mysqld/mysqld.sock --user=root --database=mirbase; \
  for t in *.tsv; do \
    mysqlimport --protocol=socket --socket=/var/run/mysqld/mysqld.sock --local --user root mirbase "$t"; \
  done; \
  \
  rm -rf /opt/seed; \
  mysqladmin --protocol=socket --socket=/var/run/mysqld/mysqld.sock shutdown; \
  cd /

WORKDIR /usr/mirna
